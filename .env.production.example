# Server
NODE_ENV=production
PORT=5000

# Database
MONGO_URI=mongodb+srv://luxstay_user:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/luxstay?retryWrites=true&w=majority

# JWT
JWT_SECRET=GENERATE_64_CHAR_RANDOM_STRING_HERE
JWT_REFRESH_SECRET=GENERATE_DIFFERENT_64_CHAR_RANDOM_STRING_HERE

# Redis
REDIS_URL=redis://default:PASSWORD@HOST:PORT

# Email (Gmail)
EMAIL_USER=your.hotel.email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
EMAIL_FROM=LuxStay Hotels <your.hotel.email@gmail.com>

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Chapa
CHAPA_SECRET_KEY=your_chapa_secret_key

# Frontend URL
CLIENT_URL=https://your-app.vercel.app
